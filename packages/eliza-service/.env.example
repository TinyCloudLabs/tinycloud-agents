# @tinycloud/eliza-service — environment template.
# Copy to `.env` in THIS directory and fill in. Bun auto-loads `.env` from the
# cwd, so run the service from packages/eliza-service/ (or export these in the
# launching shell). Real `.env` is gitignored; this `.example` is tracked.
#
# Start:  bun src/index.ts   (from packages/eliza-service/)

# ── Layer-1 service auth (REQUIRED) ───────────────────────────────────────────
# Shared secret for the tinychat app. MUST be byte-identical to the tinychat
# backend's ELIZA_SERVICE_SECRET — it's the credential→app map key, resolved to
# the frozen tinychat agentId at startup (docs/layer1-contract.md §app map).
ELIZA_SERVICE_SECRET=

# ── Agent identity (REQUIRED) ─────────────────────────────────────────────────
# Path to the agent key file. The agent DID all tinychat users delegate to is
# derived from this key (currently did:pkh:eip155:1:0x83cD9777…DcdDE01c) — it
# MUST match tinychat's AGENT_DID. The repo-keeps it at the repo root; use an
# absolute path, or this repo-root-relative path when run from this package dir.
# On boot the service logs `agentDid=…` — confirm it matches.
TINYCLOUD_AGENT_KEY_FILE=../../.tinycloud/agent.key

# TinyCloud node the agent reaches for delegated SQL/KV.
# Default: https://node.tinycloud.xyz  (prod TEE: https://tee.node.tinycloud.xyz)
TINYCLOUD_HOST=https://node.tinycloud.xyz

# ── Tools (REQUIRED for the web_search tool) ──────────────────────────────────
# Consumed by src/actions/web-search.ts. Without it, web_search returns
# 500 { error: "tool_misconfigured" } (the service still boots).
TAVILY_API_KEY=

# ── Server bind (OPTIONAL — sensible defaults) ────────────────────────────────
# Port (default 3000). Also accepts TINYCLOUD_ELIZA_SERVICE_PORT.
PORT=3000
# Bind hostname (default 0.0.0.0). Also accepts TINYCLOUD_ELIZA_SERVICE_HOST.
HOST=0.0.0.0
# Aliases for PORT/HOST (used only if PORT/HOST are unset).
# TINYCLOUD_ELIZA_SERVICE_PORT=3000
# TINYCLOUD_ELIZA_SERVICE_HOST=0.0.0.0

# ── Auth/tenant mode (OPTIONAL — leave unset) ─────────────────────────────────
# The production boot path (runtime-host.ts _bootProduction) sets these itself
# (delegation + multi-tenant). Do NOT set them by hand unless you are overriding
# the boot mode for a non-default deployment.
# TINYCLOUD_AUTH_MODE=delegation
# TINYCLOUD_MULTI_TENANT=1

# ── Deploy note ───────────────────────────────────────────────────────────────
# For Phala CVM deployment (Dockerfile + docker-compose.phala.yml), the agent key
# is mounted as a file and TINYCLOUD_AGENT_KEY_FILE points at the mount path
# (default /run/secrets/agent.key). There is NO local SQLite DB to persist — all
# durable memory lives on TINYCLOUD_HOST. See DEPLOY.md.
