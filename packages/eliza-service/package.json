{
  "name": "@tinycloud/eliza-service",
  "version": "0.1.0",
  "description": "Long-lived HTTP service hosting ElizaOS AgentRuntime(s) backed by TinyCloud multi-tenant memory (Milestone C).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@tinycloud/eliza-plugin-memory": "workspace:*",
    "@tinycloud/agent-client": "workspace:*",
    "@elizaos/core": "2.0.0-beta.1",
    "@elizaos/plugin-sql": "2.0.0-beta.1",
    "siwe": "^3.0.0",
    "viem": "^2.21.53"
  },
  "devDependencies": {
    "@elizaos/core": "2.0.0-beta.1",
    "@elizaos/plugin-sql": "2.0.0-beta.1"
  },
  "author": "TinyCloud Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TinyCloudLabs/tinycloud-agents"
  },
  "publishConfig": {
    "access": "public"
  }
}
